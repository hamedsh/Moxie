# Database Type: sqlite, mysql, postgresql
DB_TYPE=sqlite

# SQLite Configuration (used when DB_TYPE=sqlite)
DB_PATH=app.db

# MySQL Configuration (used when DB_TYPE=mysql)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
